# 🗄️ MAXXPHARM AI-CRM BOT ENVIRONMENT CONFIGURATION
# Скопируйте этот файл в .env и заполните реальные значения

# 🤖 Telegram Bot Configuration
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
ADMIN_ID=YOUR_ADMIN_TELEGRAM_ID_HERE

# 🗄️ Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=maxxpharm_crm

# 🧠 AI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# 🔄 Redis Configuration (для Celery)
REDIS_URL=redis://localhost:6379/0

# 📊 Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=maxxpharm_bot.log

# 🌍 Environment
ENVIRONMENT=development
DEBUG=True

# 📡 API Configuration (если нужен внешний API)
API_HOST=localhost
API_PORT=8000

# 🔐 Security
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here

# 📈 Monitoring (опционально)
PROMETHEUS_PORT=9090
ENABLE_METRICS=False
